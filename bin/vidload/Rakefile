require "bundler/gem_tasks"

desc "Prepare changelogs for next release"
task :changelog do
  sh "git add CHANGELOG.md"
  sh "git commit -m 'chore(changelog): update with changes of next release'"
end

desc "Dryrun release of new gem version"
task :gem_release_dryrun, [:bump_level] do |t, args|
  args.with_defaults(bump_level: ENV["BUMP_LEVEL"] || "patch")
  sh "./scripts/release-dryrun.sh #{args[:bump_level]}"
end

desc "Release new gem version"
task :gem_release, [:bump_level] do |t, args|
  args.with_defaults(bump_level: ENV["BUMP_LEVEL"] || "patch")
  sh "./scripts/release.sh #{args[:bump_level]}"
end
